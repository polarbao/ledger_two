# 生产部署环境变量配置示例
APP_ENV=production
HTTP_ADDR=:8080
APP_PORT=38088
APP_BASE_URL=http://localhost:38088
DB_DSN=/app/data/ledger.db
BACKUP_DIR=/app/backups
UPLOAD_DIR=/app/uploads
LOG_DIR=/app/logs
JWT_SECRET=please-change-me-to-a-64-character-random-secret-before-production
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
TZ=Asia/Shanghai
