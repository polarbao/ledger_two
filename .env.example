# 生产部署环境变量配置示例
APP_ENV=production

# 服务监听地址与外部映射端口
HTTP_ADDR=:8080
APP_PORT=38088
APP_BASE_URL=http://localhost:38088

# 数据库、备份与文件存储目录
DB_DSN=/app/data/ledger.db
BACKUP_DIR=/app/backups
UPLOAD_DIR=/app/uploads
LOG_DIR=/app/logs

# 安全密钥 (生产环境强制校验，不得使用开发默认值)
# 推荐生成强随机密钥命令：openssl rand -hex 32
JWT_SECRET=change-this-to-a-long-random-secret-key

# Cookie 安全策略与 SameSite 机制
# HTTPS 反向代理模式部署时设为 true，仅 HTTP 局域网访问设为 false
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax

# 容器时区
TZ=Asia/Shanghai
