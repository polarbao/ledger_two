COMPOSE_PROJECT_NAME=ledger-two-v13-staging
CONTAINER_NAME=ledger-two-v13-staging
CANDIDATE_IMAGE=ledger-two:1.3.0-rc-task50.6-<commit>
IMPORT_CLASSIFICATION_MODE=off
APP_PORT=38091
APP_BASE_URL=http://localhost:38091
RUNTIME_ROOT=/absolute/path/to/isolated/ledger-two-v13-staging
JWT_SECRET=replace-with-a-random-secret-of-at-least-32-characters
COOKIE_SECURE=false
COOKIE_SAMESITE=Lax
